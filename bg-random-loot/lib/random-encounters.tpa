    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x - 15) py = (y - 15)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 15) py = (y - 15)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x - 15) py = (y + 15)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 30) py = (y + 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x - 30) py = (y - 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
    END
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 30) py = (y - 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Bhobgob~ pres = ~BHOBGOB~
