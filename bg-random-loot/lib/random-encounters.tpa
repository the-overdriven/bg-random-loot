//----------------------- move to random location -------------------------

RANDOM_SEED TIME

DEFINE_ACTION_FUNCTION PLACE_RANDOM_NPC
  INT_VAR px = 0 py = 0
  STR_VAR parea = ~~ pname = ~~ pres = ~~
BEGIN
  COPY_EXISTING ~%parea%.are~ ~override~
    LPF fj_are_structure
      INT_VAR
        fj_loc_x       = px
        fj_loc_y       = py
        fj_dest_x      = px
        fj_dest_y      = py
        fj_orientation = 0
        fj_schedule    = "-1"
      STR_VAR
        fj_structure_type = ~actor~
        fj_name           = EVAL ~%pname%~
        fj_cre_resref     = EVAL ~%pres%~
    END
  BUT_ONLY
END

// 1. Define the Location Pool
ACTION_DEFINE_ASSOCIATIVE_ARRAY loc_area BEGIN 0=>~AR2900~ 1=>~AR4300~ 2=>~AR2700~ 3=>~AR4000~ 4=>~AR0400~ 5=>~AR4500~ 6=>~AR3802~ 7=>~AR1800~ 8=>~AR5100~ 9=>~AR3900~ 10=>~AR4400~ 11=>~AR3200~ 12=>~AR1900~ 13=>~AR1900~ 14=>~AR2400~ 15=>~AR5300~ 16=>~AR5300~ 17=>~AR4400~ END
ACTION_DEFINE_ASSOCIATIVE_ARRAY loc_x    BEGIN 0=>1815     1=>1670     2=>1155     3=>3890     4=>4802     5=>1427     6=>232      7=>2796     8=>1312     9=>1671     10=>985      11=>1412     12=>1763     13=>4416     14=>4262     15=>1160     16=>4215     17=>4044     END
ACTION_DEFINE_ASSOCIATIVE_ARRAY loc_y    BEGIN 0=>2225     1=>3555     2=>490      3=>1200     4=>213      5=>2398     6=>219      7=>3065     8=>539      9=>3042     10=>3220     11=>913      12=>3093     13=>2953     14=>3230     15=>2630     16=>3439     17=>1130     END

// 2. Define the NPC Pool
ACTION_DEFINE_ASSOCIATIVE_ARRAY npc_name BEGIN 0=>~Borda~ 1=>~Meilum~ 2=>~Denak~ 3=>~Kirian~ 4=>~Narcillicus~ 5=>~Sendai~ 6=>~Ludrug~ 7=>~Neville~ 8=>~Baruk~ 9=>~Teyngan~ 10=>~Zargal~ 11=>~Shoal~ 12=>~Zhurlong~ 13=>~Cattack~ 14=>~Arghain~ 14=>~Vax~ 15=>~Zal~ 16=>~Larry~ 17=>~Ioin~ END
ACTION_DEFINE_ASSOCIATIVE_ARRAY npc_res  BEGIN 0=>~BORDA~ 1=>~MEILUM~ 2=>~DENAK~ 3=>~KIRIAN~ 4=>~NARCIL~      5=>~SENDAI~ 6=>~GNOLL5~ 7=>~NEVILL~  8=>~BARUK~ 9=>~TEYNGA~  10=>~ZARGAL~ 11=>~SHOAL~ 12=>~HOBGZHUR~ 13=>~CATTAC~  14=>~ARGHAI~  14=>~VAX~ 15=>~ZAL~ 16=>~LARRY~ 17=>~CANTO~ END

OUTER_SET num_locs = 18
OUTER_SET num_npcs = 18

// 3. Initialize Index Array for Shuffling
OUTER_FOR (i = 0; i < num_locs; i += 1) BEGIN
  OUTER_SET $loc_indices(~%i%~) = i
END

// 4. Fisher-Yates Shuffle
RANDOM_SEED TIME
OUTER_FOR (i = num_locs - 1; i > 0; i -= 1) BEGIN
  OUTER_SET j = RANDOM(0 i)
  OUTER_SET temp = $loc_indices(~%i%~)
  OUTER_SET $loc_indices(~%i%~) = $loc_indices(~%j%~)
  OUTER_SET $loc_indices(~%j%~) = temp
END

// 5. Sequential Assignment
OUTER_FOR (i = 0; i < num_npcs; i += 1) BEGIN
  // Grab NPC data
  OUTER_SPRINT name $npc_name(~%i%~)
  OUTER_SPRINT res  $npc_res(~%i%~)

  // Grab a unique location index from the shuffled list
  OUTER_SET    s_idx = $loc_indices(~%i%~)
  OUTER_SPRINT area  $loc_area(~%s_idx%~)
  OUTER_SET    x     = $loc_x(~%s_idx%~)
  OUTER_SET    y     = $loc_y(~%s_idx%~)

  PRINT ~Randomizing: %name% moved to %area% [%x%, %y%]~

  LAF PLACE_RANDOM_NPC
    INT_VAR px = x py = y
    STR_VAR parea = EVAL ~%area%~ pname = EVAL ~%name%~ pres = EVAL ~%res%~
  END
END

// patch for Neville's hobgoblins
COPY_EXISTING ~NEVILL.DLG~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    REPLACE_TEXTUALLY ~CreateCreature("HOBGOBA",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("HOBGOBA",[-1.-1],S)~
  END
BUT_ONLY

