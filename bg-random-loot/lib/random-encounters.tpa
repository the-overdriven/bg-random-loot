  END

  // If the leader is GNOLL5 (Ludrug), pull the rest of the group to the same spot
  ELSE ACTION_IF ("%res%" STRING_EQUAL_CASE "GNOLL5") BEGIN
    // Place GNOLL5A x2
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 30) py = (y + 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Gnoll5a~ pres = ~GNOLL5A~
    END
	LAF PLACE_RANDOM_NPC
      INT_VAR px = (x - 30) py = (y - 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Gnoll5a~ pres = ~GNOLL5A~
    END
  END

  // If the leader is HOBGZHUR, pull the rest of the group to the same spot
  ELSE ACTION_IF ("%res%" STRING_EQUAL_CASE "HOBGZHUR") BEGIN
    // Place HOBGOB
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 30) py = (y + 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Hobgob~ pres = ~HOBGOB~
    END
    // Place HOBGOB_B
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x - 30) py = (y + 30)
      STR_VAR parea = EVAL ~%area%~ pname = ~Hobgob_b~ pres = ~HOBGOB_B~
