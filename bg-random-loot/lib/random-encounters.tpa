//----------------------- remove actors first -------------------------

PRINT ~Removing NPC from old locations~

// AR3000: DENAK group
COPY_EXISTING ~AR3000.are~ ~override~
  READ_LONG  0x54 actor_offset
  READ_SHORT 0x58 actor_count

  // Loop backwards (from last actor to the first) to prevent offset/index shifting issues
  FOR (idx = actor_count - 1; idx >= 0; --idx) BEGIN
    SET off = actor_offset + (idx * 0x110)
    READ_ASCII (off + 0x80) cre_resref (8) NULL
    
    // Convert to uppercase to ensure case-insensitive matching
    TO_UPPER cre_resref 

    // Use PATCH_MATCH to easily check against a list of resrefs
    PATCH_MATCH ~%cre_resref%~ WITH
      ~DENAK~ ~BRENDA~ ~LASALA~ ~DIANA~ BEGIN
        LPF fj_are_structure
          INT_VAR fj_delete_mode = idx
          STR_VAR fj_structure_type = ~actor~
        END
      END
      DEFAULT
        // Do nothing if the actor doesn't match your list
    END
  END
BUT_ONLY

// AR3500: KIRIAN group
COPY_EXISTING ~AR3500.are~ ~override~
  READ_LONG  0x54 actor_offset
  READ_SHORT 0x58 actor_count

  FOR (idx = actor_count - 1; idx >= 0; --idx) BEGIN
    SET off = actor_offset + (idx * 0x110)
    READ_ASCII (off + 0x80) cre_resref (8) NULL
    
    TO_UPPER cre_resref 

    PATCH_MATCH ~%cre_resref%~ WITH
      ~KIRIAN~ ~LINDIN~ ~BAERIN~ ~PETER~ BEGIN
        LPF fj_are_structure
          INT_VAR fj_delete_mode = idx
          STR_VAR fj_structure_type = ~actor~
        END
      END
      DEFAULT
    END
  END
BUT_ONLY

// AR4500: MEILUM
COPY_EXISTING ~AR4500.are~ ~override~
  READ_LONG  0x54 actor_offset
  READ_SHORT 0x58 actor_count

  SET found_idx = "-1"
  FOR (idx = 0; idx < actor_count; ++idx) BEGIN
    SET off = actor_offset + (idx * 0x110)
    READ_ASCII (off + 0x80) cre_resref (8) NULL
    PATCH_IF (~%cre_resref%~ STRING_EQUAL_CASE ~MEILUM~) BEGIN
      SET found_idx = idx
      SET idx = actor_count
    END
  END

  PATCH_IF (found_idx >= 0) BEGIN
    LPF fj_are_structure
      INT_VAR fj_delete_mode = found_idx
      STR_VAR fj_structure_type = ~actor~
    END
  END
BUT_ONLY

