  // If the leader is CATTAC, pull the rest of the group to the same spot
  ELSE ACTION_IF ("%res%" STRING_EQUAL_CASE "CATTAC") BEGIN
    // Place BHOBGOB x7
    LAF PLACE_RANDOM_NPC
      INT_VAR px = (x + 15) py = (y + 15)
