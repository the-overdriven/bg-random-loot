  END
END

PRINT ~Patching dynamically created enemies~

// patch for Neville's hobgoblins
COPY_EXISTING ~NEVILL.DLG~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    REPLACE_TEXTUALLY ~CreateCreature("HOBGOBA",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("HOBGOBA",[-1.-1],S)~
  END
BUT_ONLY

// patch for Baruk's kobolds
COPY_EXISTING ~BARUK.DLG~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    REPLACE_TEXTUALLY ~CreateCreature("KOBCOMM",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("KOBCOMM",[-1.-1],S)~
  END
BUT_ONLY

// patch for Arghain's half-ogres
COPY_EXISTING ~ARGHAI.DLG~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    REPLACE_TEXTUALLY ~CreateCreature("OGREHA",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("OGREHA",[-1.-1],S)~
  END
BUT_ONLY

// patch for Narcils's jellies
COPY_EXISTING ~NARCIL.DLG~ ~override~
  DECOMPILE_AND_PATCH BEGIN
    REPLACE_TEXTUALLY ~CreateCreature("JELLYGR",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("JELLYGR",[-1.-1],S)~
	REPLACE_TEXTUALLY ~CreateCreature("JELLMU",\[[0-9]+\.[0-9]+\],S)~ ~CreateCreature("JELLMU",[-1.-1],S)~
  END
BUT_ONLY

// dialogue patch for Larze (don't mention Baldur's Gate city)
COPY_EXISTING ~LARZE.DLG~ ~override~
  // 1. Create the new string and get its new StrRef number
  SET new_strref = RESOLVE_STR_REF (~Huurm. I be Larze. You be <CHARNAME>. Don't try deny it. You should not have come here. You given many warning before, but you ignore them. Now you must pay. Sorry, but Larze must kill.~)

  // 2. Search the DLG for the old StrRef and replace it
  READ_LONG 0x08 state_count
  READ_LONG 0x0c state_offset
  FOR (i = 0; i < state_count; i += 1) BEGIN
    READ_LONG (state_offset + (i * 0x10)) current_strref
    PATCH_IF (current_strref = 18259) BEGIN
      WRITE_LONG (state_offset + (i * 0x10)) new_strref
    END
  END
BUT_ONLY

// deactivate trash mob spawn at AR4500 [1488, 2336] as it collides with [1427, 2398]
PRINT ~Deactivating trash mob spawn at AR4500 [1488, 2336]~
COPY_EXISTING ~AR4500.are~ ~override~
  READ_LONG 0x60 spawn_off
  READ_LONG 0x64 spawn_num
  SET idx = 0
  WHILE (idx < spawn_num) BEGIN
    SET current_spawn = spawn_off + (idx * 200)
    READ_SHORT (current_spawn + 0x20) spawn_x
    READ_SHORT (current_spawn + 0x22) spawn_y
    PATCH_IF (spawn_x = 1488 AND spawn_y = 2336) BEGIN
      WRITE_SHORT (current_spawn + 0x86) 0
      SET idx = spawn_num
    END ELSE BEGIN
      SET idx = idx + 1
    END
  END
BUT_ONLY
