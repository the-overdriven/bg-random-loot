// AR4500: MEILUM
COPY_EXISTING ~AR4500.are~ ~override~
  READ_LONG  0x54 actor_offset
  READ_SHORT 0x58 actor_count

  SET found_idx = "-1"
  FOR (idx = 0; idx < actor_count; ++idx) BEGIN
    SET off = actor_offset + (idx * 0x110)
    READ_ASCII (off + 0x80) cre_resref (8) NULL
    PATCH_IF (~%cre_resref%~ STRING_EQUAL_CASE ~MEILUM~) BEGIN
      SET found_idx = idx
      SET idx = actor_count
    END
  END

  PATCH_IF (found_idx >= 0) BEGIN
    LPF fj_are_structure
      INT_VAR fj_delete_mode = found_idx
      STR_VAR fj_structure_type = ~actor~
    END
  END
BUT_ONLY

